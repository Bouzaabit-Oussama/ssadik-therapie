rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper: Vérifier si l'utilisateur est administrateur principal
    function isAdmin() {
      return request.auth != null && 
        (request.auth.token.email == 'admin@cabinet.com' || 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin');
    }

    // Helper: Vérifier si l'assistant a le droit de modification
    function canAssistantEdit() {
      return request.auth != null && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.canEdit == true;
    }

    // Collection des réservations (leads)
    match /leads/{leadId} {
      // Formulaire public : création autorisée
      allow create: if true;
      // Lecture : tout utilisateur authentifié (Admin ou Assistant)
      allow read: if request.auth != null;
      // Modification / Suppression : Admin OU Assistant autorisé
      allow update: if isAdmin() || canAssistantEdit();
      allow delete: if isAdmin();
    }
    
    // Collection des utilisateurs (users)
    match /users/{userId} {
      // Un utilisateur peut lire son propre profil ou l'Admin peut tout lire
      allow read: if request.auth != null && (request.auth.uid == userId || isAdmin() || resource.data.email == request.auth.token.email);
      // Seul l'Admin peut créer/modifier/supprimer des comptes d'utilisateurs
      allow write: if isAdmin() || (request.auth != null && request.auth.uid == userId);
    }

  }
}
